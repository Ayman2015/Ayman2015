@model DynamicCMS.Web.Models.ContentPage
@{
    ViewData["Title"] = "Delete Page";
}

<h1>Delete Page</h1>

<div class="alert alert-warning">Are you sure you want to delete this page?</div>

<dl class="row">
    <dt class="col-sm-2">Title</dt>
    <dd class="col-sm-10">@Model.Title</dd>
    <dt class="col-sm-2">Slug</dt>
    <dd class="col-sm-10">@Model.Slug</dd>
</dl>

<form asp-action="Delete" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
